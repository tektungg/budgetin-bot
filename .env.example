# ================================
# BUDGETIN BOT — KONFIGURASI
# ================================

# Token dari @BotFather di Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# API key dari Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# ================================
# SUPABASE (wajib)
# ================================
# Ambil dari: Supabase Dashboard → Project → Settings → API

# Project URL
# Format: https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (bukan anon key!)
# Dashboard → Settings → API → service_role key
# Key ini punya full access, JANGAN expose ke client/frontend
SUPABASE_KEY=your-service-role-key-here

# ================================
# KEAMANAN (SANGAT DISARANKAN)
# ================================
# Telegram User ID kamu — bot hanya merespon user ini
# Cara cek: chat ke @userinfobot di Telegram
# Pisahkan dengan koma jika lebih dari 1 user: 111,222,333
ALLOWED_USER_IDS=123456789
