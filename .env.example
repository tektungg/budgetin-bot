# ================================
# BUDGETIN BOT — KONFIGURASI
# ================================

# Token dari @BotFather di Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# API key dari Groq (console.groq.com) — gratis, tanpa kartu kredit
GROQ_API_KEY=your_groq_api_key_here

# ================================
# SUPABASE (wajib)
# ================================
# Ambil dari: Supabase Dashboard → Project → Settings → API

# Project URL
# Format: https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (bukan anon key!)
# Dashboard → Settings → API → service_role key
# Key ini punya full access, JANGAN expose ke client/frontend
SUPABASE_KEY=your-service-role-key-here

# ================================
# KEAMANAN (opsional)
# ================================
# Kosongkan = bot bisa dipakai semua orang (public)
# Isi = hanya user tertentu yang bisa pakai (private)
#
# Telegram User ID kamu — cek via @userinfobot
# Pisahkan dengan koma jika lebih dari 1: 111,222,333
ALLOWED_USER_IDS=
